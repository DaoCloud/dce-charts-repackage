{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "LuCSI Helm Chart Values",
  "description": "LuCSI is a Lustre CSI Driver for Kubernetes",
  "properties": {
    "global": {
      "type": "object",
      "title": "Global Configuration",
      "description": "Global settings for LuCSI",
      "properties": {
        "k8sImageRegistry": {
          "type": "string",
          "title": "Kubernetes Image Registry",
          "description": "Image registry for CSI controller sidecar images (provisioner, resizer, registrar)",
          "default": "k8s.m.daocloud.io",
          "examples": [
            "registry.k8s.io",
            "k8s.m.daocloud.io"
          ]
        },
        "luscsiImageRegistry": {
          "type": "string",
          "title": "LuCSI Image Registry",
          "description": "Image registry for LuCSI driver images",
          "default": "ghcr.m.daocloud.io",
          "examples": [
            "ghcr.io",
            "ghcr.m.daocloud.io"
          ]
        },
        "kubeletRootDir": {
          "type": "string",
          "title": "Kubelet Root Directory",
          "description": "Kubelet root directory path in the host system",
          "default": "/var/lib/kubelet"
        }
      },
      "required": [
        "k8sImageRegistry",
        "luscsiImageRegistry",
        "kubeletRootDir"
      ]
    },
    "csiController": {
      "type": "object",
      "title": "CSI Controller Configuration",
      "description": "Configuration for the CSI controller deployment",
      "properties": {
        "serviceAccount": {
          "type": "object",
          "title": "Service Account",
          "properties": {
            "name": {
              "type": "string",
              "title": "Service Account Name",
              "default": "csi-luscsi-controller-sa"
            }
          }
        },
        "nodeSelector": {
          "type": "object",
          "title": "Node Selector",
          "description": "Node selector for controller pod placement",
          "default": {}
        },
        "tolerations": {
          "type": "array",
          "title": "Tolerations",
          "description": "Tolerations for controller pod scheduling",
          "default": [],
          "items": {
            "type": "object"
          }
        },
        "affinity": {
          "type": "object",
          "title": "Affinity Rules",
          "description": "Affinity rules for controller pod placement"
        },
        "provisioner": {
          "type": "object",
          "title": "CSI Provisioner Configuration",
          "properties": {
            "image": {
              "type": "object",
              "title": "Provisioner Image",
              "properties": {
                "repository": {
                  "type": "string",
                  "title": "Image Repository",
                  "default": "sig-storage/csi-provisioner"
                },
                "pullPolicy": {
                  "type": "string",
                  "title": "Image Pull Policy",
                  "enum": [
                    "IfNotPresent",
                    "Always",
                    "Never"
                  ],
                  "default": "IfNotPresent"
                },
                "tag": {
                  "type": "string",
                  "title": "Image Tag",
                  "default": "v2.0.3"
                }
              }
            },
            "resources": {
              "type": "object",
              "title": "Resource Limits",
              "description": "CPU and memory resource limits"
            }
          }
        },
        "resizer": {
          "type": "object",
          "title": "CSI Resizer Configuration",
          "properties": {
            "image": {
              "type": "object",
              "title": "Resizer Image",
              "properties": {
                "repository": {
                  "type": "string",
                  "title": "Image Repository",
                  "default": "sig-storage/csi-resizer"
                },
                "pullPolicy": {
                  "type": "string",
                  "title": "Image Pull Policy",
                  "enum": [
                    "IfNotPresent",
                    "Always",
                    "Never"
                  ],
                  "default": "IfNotPresent"
                },
                "tag": {
                  "type": "string",
                  "title": "Image Tag",
                  "default": "v1.13.1"
                }
              }
            },
            "resources": {
              "type": "object",
              "title": "Resource Limits",
              "description": "CPU and memory resource limits"
            }
          }
        }
      }
    },
    "luscsiNode": {
      "type": "object",
      "title": "LuCSI Node Configuration",
      "description": "Configuration for the LuCSI node daemonset",
      "properties": {
        "serviceAccount": {
          "type": "object",
          "title": "Service Account",
          "properties": {
            "name": {
              "type": "string",
              "title": "Service Account Name",
              "default": "csi-luscsi-node-sa"
            }
          }
        },
        "nodeDriverRegistrar": {
          "type": "object",
          "title": "Node Driver Registrar Configuration",
          "properties": {
            "image": {
              "type": "object",
              "title": "Registrar Image",
              "properties": {
                "repository": {
                  "type": "string",
                  "title": "Image Repository",
                  "default": "sig-storage/csi-node-driver-registrar"
                },
                "pullPolicy": {
                  "type": "string",
                  "title": "Image Pull Policy",
                  "enum": [
                    "IfNotPresent",
                    "Always",
                    "Never"
                  ],
                  "default": "IfNotPresent"
                },
                "tag": {
                  "type": "string",
                  "title": "Image Tag",
                  "default": "v2.0.1"
                }
              }
            },
            "resources": {
              "type": "object",
              "title": "Resource Limits",
              "description": "CPU and memory resource limits"
            }
          }
        },
        "luscsi": {
          "type": "object",
          "title": "LuCSI Driver Configuration",
          "properties": {
            "image": {
              "type": "object",
              "title": "LuCSI Driver Image",
              "properties": {
                "repository": {
                  "type": "string",
                  "title": "Image Repository",
                  "default": "luskits/luscsi"
                },
                "pullPolicy": {
                  "type": "string",
                  "title": "Image Pull Policy",
                  "enum": [
                    "IfNotPresent",
                    "Always",
                    "Never"
                  ],
                  "default": "Always"
                },
                "tag": {
                  "type": "string",
                  "title": "Image Tag",
                  "description": "Defaults to chart appVersion",
                  "default": "0.2.0"
                }
              }
            },
            "resources": {
              "type": "object",
              "title": "Resource Limits",
              "description": "CPU and memory resource limits"
            }
          }
        },
        "nodeSelector": {
          "type": "object",
          "title": "Node Selector",
          "description": "Node selector for node daemonset pod placement",
          "default": {}
        },
        "tolerations": {
          "type": "array",
          "title": "Tolerations",
          "description": "Tolerations for node daemonset pod scheduling",
          "default": [],
          "items": {
            "type": "object"
          }
        },
        "affinity": {
          "type": "object",
          "title": "Affinity Rules",
          "description": "Affinity rules for node daemonset pod placement",
          "default": {}
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "title": "Service Account Settings",
      "description": "Global service account configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "title": "Create Service Account",
          "description": "Specifies whether a service account should be created",
          "default": true
        },
        "automount": {
          "type": "boolean",
          "title": "Automount Service Account Token",
          "description": "Automatically mount a ServiceAccount's API credentials",
          "default": true
        },
        "annotations": {
          "type": "object",
          "title": "Service Account Annotations",
          "description": "Annotations to add to the service account",
          "default": {}
        },
        "name": {
          "type": "string",
          "title": "Service Account Name",
          "description": "The name of the service account to use",
          "default": "luscsi"
        }
      }
    },
    "labels": {
      "type": "object",
      "title": "Custom Labels",
      "description": "Additional labels to apply to resources",
      "default": {}
    },
    "livenessProbe": {
      "type": "object",
      "title": "Liveness Probe Configuration",
      "description": "Liveness probe settings for health checking",
      "properties": {
        "httpGet": {
          "type": "object",
          "title": "HTTP Get Probe",
          "properties": {
            "path": {
              "type": "string",
              "title": "Probe Path",
              "default": "/"
            },
            "port": {
              "type": "string",
              "title": "Probe Port",
              "default": "http"
            }
          }
        }
      }
    },
    "readinessProbe": {
      "type": "object",
      "title": "Readiness Probe Configuration",
      "description": "Readiness probe settings for health checking",
      "properties": {
        "httpGet": {
          "type": "object",
          "title": "HTTP Get Probe",
          "properties": {
            "path": {
              "type": "string",
              "title": "Probe Path",
              "default": "/"
            },
            "port": {
              "type": "string",
              "title": "Probe Port",
              "default": "http"
            }
          }
        }
      }
    }
  },
  "required": [
    "global"
  ]
}

